# Find your Client ID and Secret in your Cora App settings.
# The Client ID needs to be exposed to the browser, so it's prefixed with NEXT_PUBLIC_.
# The Secret must NOT be exposed to the browser and is used only on the server.
NEXT_PUBLIC_CORA_CLIENT_ID=your_cora_client_id_here
CORA_CLIENT_SECRET=your_cora_client_secret_here

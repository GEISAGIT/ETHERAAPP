rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // ATENÇÃO: Esta regra é insegura e permite que qualquer pessoa leia e escreva no seu Storage.
    // Usada apenas para diagnóstico e para contornar problemas de CORS no desenvolvimento.
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Permite que qualquer pessoa leia arquivos (necessário para imagens públicas como a logo).
      allow read;
      // Permite que apenas usuários autenticados escrevam (façam upload) de arquivos.
      allow write: if request.auth != null;
    }
  }
}

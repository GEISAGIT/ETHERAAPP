rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permite que um usuário autenticado leia e escreva sua própria foto de perfil.
    // O caminho deve corresponder exatamente ao UID do usuário.
    match /profile-pictures/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Permite a leitura pública da imagem do logotipo da aplicação.
    match /teste/simbolo_semfundo_verdeclaro.png {
      allow read: if true;
    }
  }
}

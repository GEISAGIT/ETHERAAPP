
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Checks if the user is an administrator by verifying their email address.
     * This is a temporary method for the prototype. In production, custom claims are preferred.
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'grupodallax@gmail.com';
    }

    /**
     * Checks if the user is the original creator of an existing document.
     * This is used for update/delete operations on existing resources.
     */
    function isOriginalCreator() {
      // For create operations, resource is null, so we check request.resource
      let data = resource == null ? request.resource.data : resource.data;
      return isSignedIn() && request.auth.uid == data.userId;
    }
    
    // ----------------------------------------------------------------------
    // Specific Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description User profiles.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    /**
      * @description Global incomes and expenses collections.
      * @path /incomes/{docId}, /expenses/{docId}
      */
    match /{collectionName}/{docId} where collectionName in ['incomes', 'expenses'] {
        allow read: if isSignedIn();
        allow write: if isOriginalCreator() || isAdmin();
    }
    
    /**
     * @description Role definitions. Readable by any signed-in user, writable only by admins.
     * @path /roles/{roleId}
     */
    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    /**
     * @description Global budget records.
     * @path /budgets/{budgetId}
     */
    match /budgets/{budgetId} {
      // Only the user who created the budget or an admin can read/write.
      allow read, write: if (isOriginalCreator() || isAdmin());
      // Admins can list all budgets
      allow list: if isAdmin();
    }

    /**
     * @description Category definitions for income. Readable by all signed-in users.
     *              Creation is open to any user, but updates/deletes are admin-only.
     * @path /incomeCategories/{categoryId}
     */
    match /incomeCategories/{categoryId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
    }

    /**
     * @description New hierarchical expense category groups.
     *              Readable by all signed-in users. Writable only by admins.
     * @path /expenseCategoryGroups/{groupId}
     */
    match /expenseCategoryGroups/{groupId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin();
    }
  }
}

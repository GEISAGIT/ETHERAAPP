
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the ClinicFlow application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "role": {
          "type": "string",
          "description": "The user's role in the application (e.g., 'admin', 'user').",
          "enum": [
            "admin",
            "user"
          ]
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "fullName",
        "createdAt",
        "updatedAt"
      ]
    },
    "Address": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Address",
      "type": "object",
      "description": "Represents a registered address in the system.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "label": { "type": "string", "description": "A nickname for the address (e.g., 'Main Office')" },
        "street": { "type": "string" },
        "number": { "type": "string" },
        "complement": { "type": "string" },
        "district": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zipCode": { "type": "string" },
        "validityDate": { "type": "string", "format": "date-time", "description": "The expiration date of this address record" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "label", "street", "city", "state", "zipCode"]
    },
    "AttendanceRecord": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AttendanceRecord",
      "type": "object",
      "description": "Represents a time tracking record for an employee.",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "timestamp": { "type": "string", format: "date-time" },
        "type": { "type": "string", enum: ["clock_in", "clock_out", "break_start", "break_end"] },
        "photoUrl": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        }
      },
      "required": ["id", "employeeId", "timestamp", "type"]
    },
    "StockItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StockItem",
      "type": "object",
      "description": "Represents an item in the clinic's inventory.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "minQuantity": { "type": "number" },
        "unit": { "type": "string" },
        "lastRestock": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["id", "name", "quantity", "unit"]
    },
    "UserManagement": {
       "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserManagement",
      "type": "object",
      "description": "Represents user data for management purposes.",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", format: "email" },
        "role": { "type": "string", enum: ["admin", "user"] },
        "createdAt": { "type": "string", format: "date-time" }
      }
    },
    "Role": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Role",
      "type": "object",
      "description": "Defines a user role and its specific permissions for accessing different parts of the application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "The name of the role, either 'admin' or 'user'."
        },
        "permissions": {
          "type": "object",
          "description": "A map of feature names to granular permission actions.",
          "properties": {
            "dashboard": { "type": "object", "properties": { "view": { "type": "boolean" } } },
            "transactions": { "type": "object", "properties": { "view": { "type": "boolean" }, "create": { "type": "boolean" }, "edit": { "type": "boolean" }, "delete": { "type": "boolean" } } },
            "contracts": { "type": "object", "properties": { "view": { "type": "boolean" }, "create": { "type": "boolean" }, "edit": { "type": "boolean" }, "delete": { "type": "boolean" } } },
            "expenses": { "type": "object", "properties": { "view": { "type": "boolean" }, "create": { "type": "boolean" }, "edit": { "type": "boolean" }, "delete": { "type": "boolean" } } },
            "budgets": { "type": "object", "properties": { "view": { "type": "boolean" }, "create": { "type": "boolean" }, "edit": { "type": "boolean" }, "delete": { "type": "boolean" } } },
            "reports": { "type": "object", "properties": { "view": { "type": "boolean" } } },
            "upload": { "type": "object", "properties": { "view": { "type": "boolean" }, "create": { "type": "boolean" }, "edit": { "type": "boolean" }, "delete": { "type": "boolean" } } },
            "userManagement": { "type": "object", "properties": { "view": { "type": "boolean" }, "create": { "type": "boolean" }, "edit": { "type": "boolean" }, "delete": { "type": "boolean" } } },
            "profile": { "type": "object", "properties": { "view": { "type": "boolean" }, "edit": { "type": "boolean" } } },
            "settings": { "type": "object", "properties": { "view": { "type": "boolean" } } },
            "addresses": { "type": "object", "properties": { "view": { "type": "boolean" }, "create": { "type": "boolean" }, "edit": { "type": "boolean" }, "delete": { "type": "boolean" } } }
          }
        }
      },
      "required": ["id", "permissions"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/stock/{itemId}": {
      "schema": "#/backend/entities/StockItem",
      "description": "Clinic inventory items."
    },
    "/addresses/{addressId}": {
      "schema": "#/backend/entities/Address",
      "description": "Registered business or personal addresses."
    }
  }
}

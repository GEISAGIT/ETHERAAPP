{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the ClinicFlow application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "status": { "type": "string", "enum": ["active", "pending", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "fullName", "createdAt", "updatedAt"]
    },
    "Activity": {
      "title": "Activity",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "in_progress", "waiting_validation", "completed", "rework"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "urgent"] },
        "requesterId": { "type": "string" },
        "assigneeId": { "type": "string" },
        "isPrivate": { "type": "boolean" },
        "viewerIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Budget": {
      "title": "Budget",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "spent": { "type": "number" }
      }
    },
    "Contract": {
      "title": "Contract",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["fixed", "variable"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["active", "cancelled", "expired"] },
        "paymentFrequency": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "StockCategory": {
      "title": "Stock Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subCategories": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "options": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      },
      "required": ["id", "name"]
    },
    "ItemCatalog": {
      "title": "Item Catalog",
      "type": "object",
      "description": "Master product catalog definitions (SKUs).",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "unit": { "type": "string" }
      }
    },
    "Patient": {
      "title": "Patient",
      "type": "object",
      "description": "Comprehensive patient clinical and demographic data.",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "cpf": { "type": "string" },
        "birthDate": { "type": "string", "format": "date-time" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "death"] },
        "bloodType": { "type": "string" },
        "allergies": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/activities/{activityId}": {
      "schema": "#/backend/entities/Activity",
      "description": "Task management activities."
    },
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "User profiles and permissions."
    },
    "/budgets/{budgetId}": {
      "schema": "#/backend/entities/Budget",
      "description": "User financial budgets."
    },
    "/contracts/{contractId}": {
      "schema": "#/backend/entities/Contract",
      "description": "Recurring contracts and subscriptions."
    },
    "/stockCategories/{categoryId}": {
      "schema": "#/backend/entities/StockCategory",
      "description": "Hierarchical categories for stock items."
    },
    "/itemCatalog/{itemId}": {
      "schema": "#/backend/entities/ItemCatalog",
      "description": "Unique SKUs and item definitions."
    },
    "/stock/{batchId}": {
      "schema": { "type": "object" },
      "description": "Physical inventory batches."
    },
    "/incomes/{docId}": {
      "schema": { "type": "object" },
      "description": "Financial income transactions."
    },
    "/expenses/{docId}": {
      "schema": { "type": "object" },
      "description": "Financial expense transactions."
    },
    "/patients/{patientId}": {
      "schema": "#/backend/entities/Patient",
      "description": "Patient records and clinical history metadata."
    }
  }
}

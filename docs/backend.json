
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the ClinicFlow application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "fullName": {
          "type": "string",
          "description": "The user's full name."
        },
        "role": {
          "type": "string",
          "description": "The user's role in the application (e.g., 'admin', 'user').",
          "enum": [
            "admin",
            "user"
          ]
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp indicating when the user account was last updated.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "fullName",
        "createdAt",
        "updatedAt"
      ]
    },
    "StorageLocation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StorageLocation",
      "type": "object",
      "description": "Represents a physical storage location within the clinic (Room, Cabinet, Drawer).",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string", "description": "Name of the location (e.g., 'Sala 1')" },
        "description": { "type": "string", "description": "Details (e.g., 'Armário B, Gaveta 2')" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "StockItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "StockItem",
      "type": "object",
      "description": "Represents an item in the clinic's inventory.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "minQuantity": { "type": "number" },
        "unit": { "type": "string" },
        "locationId": { "type": "string", "description": "Reference to StorageLocation" },
        "locationName": { "type": "string" },
        "manufacturingDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "lastRestock": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["id", "name", "quantity", "unit", "locationId"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/stock/{itemId}": {
      "schema": "#/backend/entities/StockItem",
      "description": "Clinic inventory items."
    },
    "/storageLocations/{locationId}": {
      "schema": "#/backend/entities/StorageLocation",
      "description": "Physical storage units (Rooms, Cabinets)."
    }
  }
}

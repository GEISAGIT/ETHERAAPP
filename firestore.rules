
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Funções Auxiliares de Segurança
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Administrador Mestre (Verificação direta por Token - Sem latência de banco)
    function isMasterAdmin() {
      return isSignedIn() && request.auth.token.email == 'grupodallax@gmail.com';
    }

    // Verifica se o usuário logado tem o papel de 'admin' no documento de perfil
    function isAdmin() {
      if (!isSignedIn()) return false;
      if (isMasterAdmin()) return true;
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) && get(userPath).data.role == 'admin';
    }

    // Função genérica para verificar permissões granulares
    function hasPermission(module, action) {
      if (!isSignedIn()) return false;
      if (isMasterAdmin()) return true;
      
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      if (!exists(userPath)) return false;
      let userData = get(userPath).data;
      
      // Se for admin no perfil, libera tudo
      if (userData.role == 'admin') return true;
      
      return userData.get('permissions', {}).get(module, {}).get(action, false) == true;
    }

    // ----------------------------------------------------------------------
    // Regras por Coleção
    // ----------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isMasterAdmin() || isAdmin() || hasPermission('userManagement', 'view');
      allow list: if isMasterAdmin() || isAdmin() || hasPermission('userManagement', 'view');
      allow create: if isOwner(userId) || isMasterAdmin() || isAdmin();
      allow update: if isOwner(userId) || isMasterAdmin() || isAdmin() || hasPermission('userManagement', 'edit');
      allow delete: if isMasterAdmin() || isAdmin();

      match /coraTokens/{tokenId} {
        allow read, write: if isOwner(userId) || isMasterAdmin() || isAdmin();
      }
    }

    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow write: if isMasterAdmin() || isAdmin();
    }
    
    match /incomes/{docId} {
        allow get: if isSignedIn() && (isMasterAdmin() || isAdmin() || resource.data.userId == request.auth.uid || hasPermission('transactions', 'view'));
        allow list: if isSignedIn() && (isMasterAdmin() || isAdmin() || hasPermission('transactions', 'view'));
        allow create: if isMasterAdmin() || isAdmin() || hasPermission('transactions', 'create');
        allow update: if isMasterAdmin() || isAdmin() || hasPermission('transactions', 'edit');
        allow delete: if isMasterAdmin() || isAdmin() || hasPermission('transactions', 'delete');
    }

    match /expenses/{docId} {
        allow get: if isSignedIn() && (isMasterAdmin() || isAdmin() || resource.data.userId == request.auth.uid || hasPermission('transactions', 'view'));
        allow list: if isSignedIn() && (isMasterAdmin() || isAdmin() || hasPermission('transactions', 'view'));
        allow create: if isMasterAdmin() || isAdmin() || hasPermission('transactions', 'create');
        allow update: if isMasterAdmin() || isAdmin() || hasPermission('transactions', 'edit');
        allow delete: if isMasterAdmin() || isAdmin() || hasPermission('transactions', 'delete');
    }

    match /budgets/{budgetId} {
      allow read: if isMasterAdmin() || isAdmin() || hasPermission('budgets', 'view') || (resource != null && resource.data.userId == request.auth.uid);
      allow create: if isMasterAdmin() || isAdmin() || hasPermission('budgets', 'create');
      allow update: if isMasterAdmin() || isAdmin() || hasPermission('budgets', 'edit');
      allow delete: if isMasterAdmin() || isAdmin() || hasPermission('budgets', 'delete');
    }

    match /incomeCategories/{categoryId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isMasterAdmin() || isAdmin();
    }

    match /expenseCategoryGroups/{groupId} {
        allow get, list: if isSignedIn();
        allow write: if isMasterAdmin() || isAdmin();
    }

    match /contracts/{contractId} {
      allow get: if isSignedIn() && (isMasterAdmin() || isAdmin() || resource.data.userId == request.auth.uid || hasPermission('transactions', 'view'));
      allow list: if isSignedIn() && (isMasterAdmin() || isAdmin() || hasPermission('transactions', 'view'));
      allow create: if isMasterAdmin() || isAdmin() || hasPermission('transactions', 'create') || hasPermission('settings', 'view');
      allow update: if isMasterAdmin() || isAdmin() || hasPermission('transactions', 'edit') || hasPermission('settings', 'view');
      allow delete: if isMasterAdmin() || isAdmin() || hasPermission('transactions', 'delete') || hasPermission('settings', 'view');
    }

    match /employees/{employeeId} {
      allow get: if isSignedIn() && (isMasterAdmin() || isAdmin() || hasPermission('employees', 'view'));
      allow list: if isSignedIn() && (isMasterAdmin() || isAdmin() || hasPermission('employees', 'view'));
      allow create: if isMasterAdmin() || isAdmin() || hasPermission('employees', 'create');
      allow update: if isMasterAdmin() || isAdmin() || hasPermission('employees', 'edit');
      allow delete: if isMasterAdmin() || isAdmin() || hasPermission('employees', 'delete');
    }

    match /attendanceRecords/{recordId} {
      // Regra para visualizar histórico (lista)
      // Se for Admin ou tiver permissão de RH, vê tudo.
      // Se for usuário comum, o Firestore exige que a query tenha o filtro 'employeeId == uid'
      allow list: if isSignedIn() && (
        isMasterAdmin() || 
        isAdmin() || 
        hasPermission('timeTracking', 'view') ||
        (request.query.limit <= 500 && resource.data.employeeId == request.auth.uid)
      );

      // Regra para ver um documento específico
      allow get: if isSignedIn() && (
        isMasterAdmin() || 
        isAdmin() || 
        hasPermission('timeTracking', 'view') || 
        resource.data.employeeId == request.auth.uid
      );

      allow create: if isSignedIn() && (
        isMasterAdmin() || 
        isAdmin() || 
        (request.resource.data.employeeId == request.auth.uid && hasPermission('timeTracking', 'create')) || 
        hasPermission('hrTimesheet', 'create')
      );

      allow update, delete: if isMasterAdmin() || isAdmin() || hasPermission('hrTimesheet', 'edit');
    }
  }
}

/**
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model. All user-generated
 * data, including financial records like incomes, expenses, categories, and
 * budgets, is stored in subcollections specific to each user. Access is
 * granted only if the requesting user's UID matches the user ID in the
 * document path, ensuring complete data isolation between users.
 *
 * Data Structure:
 * All data is organized under a top-level `/users` collection. Each user's
 * data is segregated into a document tree identified by their unique user ID
 * (e.g., `/users/{userId}/incomes/{incomeId}`). This structure is fundamental
 * to the security model.
 *
 * Key Security Decisions:
 * - Strict Data Isolation: Users can ONLY read and write data within their
 *   own data tree (`/users/{userId}`). Cross-user access is explicitly denied.
 * - No Public Data: There are no globally readable collections. All access
 *   requires authentication.
 * - No User Listing: It is not possible to list documents in the top-level
 *   `/users` collection, preventing enumeration of all application users.
 * - Ownership-Based Writes: All write operations (create, update, delete)
 *   are strictly limited to the owner of the data.
 *
 * Denormalization for Authorization:
 * This ruleset leverages a path-based security model, which is a form of
 * denormalization. The owner's `userId` is part of the document path,
 * eliminating the need for slow and costly `get()` calls to other documents
 * to verify ownership. Rules are fast and efficient.
 *
 * Structural Segregation:
 * The data model inherently uses structural segregation by creating separate
 * subcollections (`incomes`, `expenses`, etc.) for each user. This is more
 * secure and performant than co-mingling data from multiple users in a single
 * top-level collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for improved readability and maintainability.

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Verifies if the authenticated user's ID matches the owner ID from the path.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Verifies ownership for an existing document. Used for update and delete
     * operations to prevent acting on non-existent data.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // Match all user-specific subcollections (incomes, expenses, categories, budgets).
    // This single rule block enforces a consistent ownership policy across all of a user's private data.
    match /users/{userId}/{subcollection}/{docId} {
      /**
       * @description Grants a user full read/write access to their own subcollection documents (e.g., incomes, expenses), but denies all access to other users' data.
       * @path        /users/{userId}/{subcollection}/{docId}
       * @allow       (create) An authenticated user 'user_abc' can create a new document at `/users/user_abc/incomes/new_income`.
       * @deny        (get) An authenticated user 'user_xyz' is denied from reading `/users/user_abc/incomes/some_income`.
       * @principle   Restricts access to a user's own data tree based on path ownership.
       */
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}
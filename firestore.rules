
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // FUNÇÕES DE APOIO
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // Identificação instantânea por Token (E-mail) - O mais seguro e rápido para o Dono
    function isMaster() {
      return isSignedIn() && (
        request.auth.token.email == 'grupodallax@gmail.com' || 
        request.auth.token.email == 'vasin71888@him6.com'
      );
    }

    // Verifica permissão no documento do usuário de forma dinâmica conforme definido no Admin
    function hasPermission(page, action) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isMaster() || (userDoc.permissions[page][action] == true);
    }

    // ----------------------------------------------------------------------
    // REGRAS POR COLEÇÃO
    // ----------------------------------------------------------------------

    // Usuários: Dono ou quem tem permissão de gerenciamento acessam.
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isMaster() || hasPermission('userManagement', 'view'));
      allow write: if isSignedIn() && (request.auth.uid == userId || isMaster() || hasPermission('userManagement', 'edit'));
    }

    // Novo Cartão de Ponto (Simples)
    match /timeEntries/{entryId} {
      // Regra de listagem: Admin vê tudo, usuário vê o seu, se tiver a permissão habilitada no Admin
      allow list: if isSignedIn() && (isMaster() || (request.query.limit <= 500 && resource.data.userId == request.auth.uid && hasPermission('timeCard', 'view')));
      allow get: if isSignedIn() && (isMaster() || resource.data.userId == request.auth.uid || hasPermission('timeCard', 'view'));
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isMaster());
      allow update, delete: if isMaster();
    }

    // Controle de Ponto (Beta)
    match /attendanceRecords/{recordId} {
      allow list: if isSignedIn() && (isMaster() || (request.query.limit <= 500 && resource.data.employeeId == request.auth.uid && hasPermission('timeTracking', 'view')));
      allow get: if isSignedIn() && (isMaster() || resource.data.employeeId == request.auth.uid || hasPermission('timeTracking', 'view'));
      allow create: if isSignedIn() && (request.resource.data.employeeId == request.auth.uid || isMaster());
      allow update, delete: if isMaster() || hasPermission('hrTimesheet', 'edit');
    }

    // Coleções Financeiras: Respeitam o que você definiu no Gerenciar Acessos
    match /incomes/{docId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('transactions', 'view'));
      allow write: if isMaster() || hasPermission('transactions', 'create');
    }

    match /expenses/{docId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('transactions', 'view'));
      allow write: if isMaster() || hasPermission('transactions', 'create');
    }

    match /contracts/{docId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('transactions', 'view'));
      allow write: if isMaster() || hasPermission('transactions', 'create');
    }

    match /budgets/{docId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('budgets', 'view'));
      allow write: if isMaster() || hasPermission('budgets', 'create');
    }

    // Configurações Gerais
    match /incomeCategories/{docId} { allow read: if isSignedIn(); allow write: if isMaster() || hasPermission('settings', 'view'); }
    match /expenseCategoryGroups/{docId} { allow read: if isSignedIn(); allow write: if isMaster() || hasPermission('settings', 'view'); }
    match /employees/{docId} { 
      allow read: if isSignedIn() && (isMaster() || hasPermission('employees', 'view')); 
      allow write: if isMaster() || hasPermission('employees', 'create'); 
    }
    match /roles/{docId} { allow read: if isSignedIn(); allow write: if isMaster(); }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Funções Auxiliares de Segurança
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Busca o documento do usuário logado
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // Verifica se o usuário logado tem o papel de 'admin'
    function isAdmin() {
      if (!isSignedIn()) return false;
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) && get(userPath).data.role == 'admin';
    }

    // Função genérica para verificar permissões granulares no mapa de permissões
    function hasPermission(module, action) {
      if (!isSignedIn()) return false;
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      if (!exists(userPath)) return false;
      let userData = get(userPath).data;
      
      return userData.role == 'admin' || 
             (userData.get('permissions', {}).get(module, {}).get(action, false) == true);
    }

    // ----------------------------------------------------------------------
    // Regras por Coleção
    // ----------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || hasPermission('userManagement', 'view');
      allow list: if hasPermission('userManagement', 'view');
      // Permite criar perfil se for RH ou Admin (necessário para cadastro de funcionários)
      allow create: if isOwner(userId) || hasPermission('employees', 'create') || hasPermission('userManagement', 'create');
      allow update: if isOwner(userId) || hasPermission('userManagement', 'edit');
      allow delete: if hasPermission('userManagement', 'delete');

      match /coraTokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /incomes/{docId} {
        allow read: if isSignedIn();
        allow list: if hasPermission('transactions', 'view') || hasPermission('reports', 'view');
        allow create: if hasPermission('transactions', 'create');
        allow update: if hasPermission('transactions', 'edit');
        allow delete: if hasPermission('transactions', 'delete');
    }

    match /expenses/{docId} {
        allow read: if isSignedIn();
        allow list: if hasPermission('transactions', 'view') || hasPermission('reports', 'view');
        allow create: if hasPermission('transactions', 'create');
        allow update: if hasPermission('transactions', 'edit');
        allow delete: if hasPermission('transactions', 'delete');
    }

    match /budgets/{budgetId} {
      allow read: if hasPermission('budgets', 'view') || resource.data.userId == request.auth.uid;
      allow create: if hasPermission('budgets', 'create');
      allow update: if hasPermission('budgets', 'edit');
      allow delete: if hasPermission('budgets', 'delete');
    }

    match /incomeCategories/{categoryId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
    }

    match /expenseCategoryGroups/{groupId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin();
    }

    match /contracts/{contractId} {
      allow read, list: if isSignedIn();
      allow create: if hasPermission('transactions', 'create') || hasPermission('settings', 'view');
      allow update: if hasPermission('transactions', 'edit') || hasPermission('settings', 'view');
      allow delete: if hasPermission('transactions', 'delete') || hasPermission('settings', 'view');
    }

    match /employees/{employeeId} {
      allow read, list: if hasPermission('employees', 'view') || hasPermission('timeTracking', 'view');
      allow create: if hasPermission('employees', 'create');
      allow update: if hasPermission('employees', 'edit');
      allow delete: if hasPermission('employees', 'delete');
    }

    match /attendanceRecords/{recordId} {
      // Dono sempre pode ler seus próprios pontos. Admin/RH podem ler tudo se tiverem permissão.
      allow read: if isSignedIn() && (
        (resource == null || resource.data.employeeId == request.auth.uid) || 
        hasPermission('timeTracking', 'view')
      );
      // Qualquer um logado pode registrar o próprio ponto se tiver permissão de criação
      // RH/Admin pode registrar ponto para qualquer um (necessário para ajuste manual)
      allow create: if isSignedIn() && (
        (request.resource.data.employeeId == request.auth.uid && hasPermission('timeTracking', 'create')) || 
        hasPermission('hrTimesheet', 'create')
      );
      allow update, delete: if isAdmin() || hasPermission('hrTimesheet', 'edit');
    }
  }
}

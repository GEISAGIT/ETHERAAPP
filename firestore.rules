
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Checks if the requesting user is an administrator.
     */
    function isAdmin() {
      // Check for the existence of the user document and its role field
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /**
     * Validates that a newly created document has a 'userId' field matching the creator.
     */
    function isCorrectUserOnCreate() {
      return request.resource.data.userId == request.auth.uid;
    }

    /**
     * Ensures a document's 'userId' field cannot be changed on update.
     */
    function isUserIdImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    /**
     * Checks if the user is the original creator of an existing document.
     */
    function isOriginalCreator() {
      return request.auth.uid == resource.data.userId;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description User profiles and their legacy subcollections.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();

      /**
       * @description Legacy user-specific income records. Read-only for data migration.
       * @path /users/{userId}/incomes/{incomeId}
       */
      match /incomes/{incomeId} {
        allow get, list: if isOwner(userId);
        allow write: if false; // Make legacy data read-only
      }

      /**
       * @description Legacy user-specific expense records. Read-only for data migration.
       * @path /users/{userId}/expenses/{expenseId}
       */
      match /expenses/{expenseId} {
        allow get, list: if isOwner(userId);
        allow write: if false; // Make legacy data read-only
      }
    }
    
    /**
     * @description Role definitions. Readable by any signed-in user, writable only by admins.
     * @path /roles/{roleId}
     */
    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Global income records. Readable by all, writable by users for their own data.
     * @path /incomes/{incomeId}
     */
    match /incomes/{incomeId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isCorrectUserOnCreate();
      allow update: if isSignedIn() && isOriginalCreator() && isUserIdImmutable();
      allow delete: if isSignedIn() && isOriginalCreator();
    }

    /**
     * @description Global expense records. Readable by all, writable by users for their own data.
     * @path /expenses/{expenseId}
     */
    match /expenses/{expenseId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isCorrectUserOnCreate();
      allow update: if isSignedIn() && isOriginalCreator() && isUserIdImmutable();
      allow delete: if isSignedIn() && isOriginalCreator();
    }

    /**
     * @description Global budget records. Readable by all, writable by admins.
     * @path /budgets/{budgetId}
     */
    match /budgets/{budgetId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Global income categories. Readable by all, writable by admins.
     * @path /incomeCategories/{categoryId}
     */
    match /incomeCategories/{categoryId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Global expense categories. Readable by all, writable by admins.
     * @path /expenseCategories/{categoryId}
     */
    match /expenseCategories/{categoryId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}

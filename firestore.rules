
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMaster() {
      return isSignedIn() && (
        request.auth.token.email == 'grupodallax@gmail.com' || 
        request.auth.token.email == 'vasin71888@him6.com'
      );
    }

    function hasPermission(page, action) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isMaster() || (
        userDoc != null && 
        userDoc.permissions != null && 
        userDoc.permissions[page] != null && 
        userDoc.permissions[page][action] == true
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isMaster() || hasPermission('userManagement', 'view'));
      allow write: if isSignedIn() && (request.auth.uid == userId || isMaster() || hasPermission('userManagement', 'edit'));
    }

    match /timeEntries/{entryId} {
      allow list: if isSignedIn() && (isMaster() || (request.query.limit <= 500 && resource.data.userId == request.auth.uid && hasPermission('timeCard', 'view')));
      allow get: if isSignedIn() && (isMaster() || resource.data.userId == request.auth.uid || hasPermission('timeCard', 'view'));
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isMaster() || hasPermission('timeCard', 'create'));
      allow update: if isMaster() || hasPermission('timeCard', 'edit');
      allow delete: if isMaster() || hasPermission('timeCard', 'delete');
    }

    match /attendanceRecords/{recordId} {
      allow list: if isSignedIn() && (isMaster() || (request.query.limit <= 500 && resource.data.employeeId == request.auth.uid && hasPermission('timeTracking', 'view')));
      allow get: if isSignedIn() && (isMaster() || resource.data.employeeId == request.auth.uid || hasPermission('timeTracking', 'view'));
      allow create: if isSignedIn() && (request.resource.data.employeeId == request.auth.uid || isMaster() || hasPermission('timeTracking', 'create'));
      allow update: if isMaster() || hasPermission('timeTracking', 'edit');
      allow delete: if isMaster() || hasPermission('timeTracking', 'delete');
    }

    match /incomes/{docId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('transactions', 'view'));
      allow create: if isMaster() || hasPermission('transactions', 'create');
      allow update: if isMaster() || hasPermission('transactions', 'edit');
      allow delete: if isMaster() || hasPermission('transactions', 'delete');
    }

    match /expenses/{docId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('transactions', 'view'));
      allow create: if isMaster() || hasPermission('transactions', 'create');
      allow update: if isMaster() || hasPermission('transactions', 'edit');
      allow delete: if isMaster() || hasPermission('transactions', 'delete');
    }

    match /contracts/{docId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('contracts', 'view'));
      allow create: if isMaster() || hasPermission('contracts', 'create');
      allow update: if isMaster() || hasPermission('contracts', 'edit');
      allow delete: if isMaster() || hasPermission('contracts', 'delete');
    }

    match /budgets/{docId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('budgets', 'view'));
      allow create: if isMaster() || hasPermission('budgets', 'create');
      allow update: if isMaster() || hasPermission('budgets', 'edit');
      allow delete: if isMaster() || hasPermission('budgets', 'delete');
    }

    match /stock/{docId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('suppliesStock', 'view'));
      allow create: if isMaster() || hasPermission('suppliesStock', 'create');
      allow update: if isMaster() || hasPermission('suppliesStock', 'edit');
      allow delete: if isMaster() || hasPermission('suppliesStock', 'delete');
    }

    match /storageLocations/{docId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('addresses', 'view'));
      allow create: if isMaster() || hasPermission('addresses', 'create');
      allow update: if isMaster() || hasPermission('addresses', 'edit');
      allow delete: if isMaster() || hasPermission('addresses', 'delete');
    }

    match /incomeCategories/{docId} { 
      allow read: if isSignedIn(); 
      allow write: if isMaster() || hasPermission('expenses', 'edit'); 
    }
    
    match /expenseCategoryGroups/{docId} { 
      allow read: if isSignedIn(); 
      allow write: if isMaster() || hasPermission('expenses', 'edit'); 
    }
    
    match /employees/{docId} { 
      allow read: if isSignedIn() && (isMaster() || hasPermission('employees', 'view')); 
      allow create: if isMaster() || hasPermission('employees', 'create');
      allow update: if isMaster() || hasPermission('employees', 'edit');
      allow delete: if isMaster() || hasPermission('employees', 'delete');
    }
    
    match /roles/{docId} { 
      allow read: if isSignedIn(); 
      allow write: if isMaster(); 
    }
  }
}

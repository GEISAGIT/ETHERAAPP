
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Checks if the requesting user is an administrator by looking at their user document.
     */
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /**
     * Validates that a newly created document has a 'userId' field matching the creator.
     */
    function isCorrectUserOnCreate() {
      return request.resource.data.userId == request.auth.uid;
    }

    /**
     * Checks if the user is the original creator of an existing document.
     */
    function isOriginalCreator() {
      return request.auth.uid == resource.data.userId;
    }
    
    // ----------------------------------------------------------------------
    // CollectionGroup Rules - These rules apply across all collections with the same name.
    // ----------------------------------------------------------------------
    
    match /{path=**}/incomes/{incomeId} {
      // Allow reading any income document if signed in. This covers both legacy and new structures.
      allow get, list: if isSignedIn();
      // Allow writing if user is the creator or an admin.
      allow write: if isSignedIn() && (isOriginalCreator() || isAdmin());
    }
    
    match /{path=**}/expenses/{expenseId} {
      // Allow reading any expense document if signed in. This covers both legacy and new structures.
      allow get, list: if isSignedIn();
      // Allow writing if user is the creator or an admin.
      allow write: if isSignedIn() && (isOriginalCreator() || isAdmin());
    }


    // ----------------------------------------------------------------------
    // Specific Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description User profiles.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin(); // Only admins can delete user documents
    }
    
    /**
     * @description Role definitions. Readable by any signed-in user, writable only by admins.
     * @path /roles/{roleId}
     */
    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    /**
     * @description Global budget records. Readable by all, writable by admins.
     * @path /budgets/{budgetId}
     */
    match /budgets/{budgetId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Category definitions. Readable by all signed-in users.
     *              Creation is open to seed defaults, but updates/deletes are admin-only.
     * @path /incomeCategories/{categoryId}, /expenseCategories/{categoryId}
     */
    match /{collectionName}/{categoryId}
      where collectionName in ['incomeCategories', 'expenseCategories'] {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
    }
  }
}

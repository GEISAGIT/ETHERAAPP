
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // FUNÇÕES MESTRAS (SEM RECURSÃO)
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    // Identificação instantânea por Token (E-mail) - Evita ler o banco
    function isMaster() {
      return isSignedIn() && (
        request.auth.token.email == 'grupodallax@gmail.com' || 
        request.auth.token.email == 'vasin71888@him6.com'
      );
    }

    // ----------------------------------------------------------------------
    // REGRAS POR COLEÇÃO
    // ----------------------------------------------------------------------

    // Usuários: Dono ou Master acessam. Sem isAdmin() circular aqui.
    match /users/{userId} {
      allow read, write: if isMaster() || (isSignedIn() && request.auth.uid == userId);
    }

    // Registros de Ponto: Filtros simplificados para Produção
    match /timeEntries/{entryId} {
      allow list: if isSignedIn() && (isMaster() || request.query.limit <= 500);
      allow get: if isSignedIn() && (isMaster() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (isMaster() || request.resource.data.userId == request.auth.uid);
      allow update, delete: if isMaster();
    }

    match /attendanceRecords/{recordId} {
      allow list: if isSignedIn() && (isMaster() || request.query.limit <= 500);
      allow get: if isSignedIn() && (isMaster() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isMaster();
    }

    // Coleções Financeiras
    match /incomes/{docId} {
      allow read: if isSignedIn() && (isMaster() || resource.data.userId == request.auth.uid);
      allow write: if isMaster();
    }

    match /expenses/{docId} {
      allow read: if isSignedIn() && (isMaster() || resource.data.userId == request.auth.uid);
      allow write: if isMaster();
    }

    match /contracts/{docId} {
      allow read: if isSignedIn() && (isMaster() || resource.data.userId == request.auth.uid);
      allow write: if isMaster();
    }

    match /budgets/{docId} {
      allow read: if isSignedIn() && (isMaster() || resource.data.userId == request.auth.uid);
      allow write: if isMaster();
    }

    // Configurações (Categorias)
    match /incomeCategories/{docId} { allow read: if isSignedIn(); allow write: if isMaster(); }
    match /expenseCategoryGroups/{docId} { allow read: if isSignedIn(); allow write: if isMaster(); }
    match /employees/{docId} { allow read: if isSignedIn(); allow write: if isMaster(); }
    match /roles/{docId} { allow read: if isSignedIn(); allow write: if isMaster(); }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Checks if the requesting user is an administrator by looking at their user document.
     */
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    /**
     * Checks if the user is the original creator of an existing document.
     * This is used for update/delete operations on existing resources.
     */
    function isOriginalCreator() {
      return request.auth.uid == resource.data.userId;
    }


    // ----------------------------------------------------------------------
    // CollectionGroup & Generic Collection Rules
    // ----------------------------------------------------------------------
    
    /**
     * @description Generic rule for all 'incomes' and 'expenses' collections,
     *              whether they are at the root or nested under a user.
     *              This rule handles all CUD operations based on ownership or admin role.
     */
    match /{path=**}/{collectionName}/{docId} 
      where collectionName in ['incomes', 'expenses'] {
      // READ: Anyone signed in can read any income or expense document.
      // This supports collectionGroup queries across all data structures.
      allow get, list: if isSignedIn();
      
      // WRITE (CREATE, UPDATE, DELETE): 
      // Only the original creator or an admin can modify.
      allow write: if isSignedIn() && (isOriginalCreator() || isAdmin());
    }


    // ----------------------------------------------------------------------
    // Specific Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description User profiles.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin(); // Only admins can delete user documents
    }
    
    /**
     * @description Role definitions. Readable by any signed-in user, writable only by admins.
     * @path /roles/{roleId}
     */
    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    /**
     * @description Global budget records. Readable by all, writable by admins.
     * @path /budgets/{budgetId}
     */
    match /budgets/{budgetId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description Category definitions. Readable by all signed-in users.
     *              Creation is open to seed defaults, but updates/deletes are admin-only.
     * @path /incomeCategories/{categoryId}, /expenseCategories/{categoryId}
     */
    match /{collectionName}/{categoryId}
      where collectionName in ['incomeCategories', 'expenseCategories'] {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
    }
  }
}

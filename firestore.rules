/**
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model where all data is private
 * to the user who created it. There is no public or shared data. The security
 * model is designed for high isolation between users.
 *
 * Data Structure:
 * The entire data model is hierarchical, with all user-specific data nested
 * under a top-level `/users/{userId}` path. This includes collections for
 * incomes, expenses, budgets, and their respective categories. This structure
 * is fundamental to the security model, as ownership is determined by the path.
 *
 * Key Security Decisions:
 * - User Isolation: A user can only read or write data within their own
 *   document tree (i.e., under `/users/{their-own-userId}`).
 * - No User Enumeration: Listing documents in the top-level `/users`
 *   collection is explicitly disallowed to prevent leaking user information.
 * - Path-Based Security: By nesting data, we avoid slow and costly `get()`
 *   calls to parent documents for authorization. Ownership is derived directly
 *   from the `{userId}` wildcard in the matched path.
 * - Relational Integrity: On document creation, rules enforce that the
 *   internal `userId` field matches the `{userId}` from the path, ensuring
 *   data consistency and correct ownership linkage. This link is immutable.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    //-------------------------------------------------------------------------
    // Helper Functions
    //-------------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the currently authenticated user's UID matches the provided userId.
     * This is the primary function for enforcing data ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if a document exists and if the requester is the owner.
     * Used for safe update and delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * Validates creation of a user's own root document.
     * Ensures the document's internal `id` matches the user's auth UID.
     */
    function isCreatingSelf(userId) {
      return isOwner(userId) && request.resource.data.id == userId;
    }

    /**
     * Validates updates to a user's own root document.
     * Ensures the user exists and that the internal `id` field is immutable.
     */
    function isUpdatingSelf(userId) {
      return isExistingOwner(userId) && request.resource.data.id == resource.data.id;
    }
    
    /**
     * Validates creation of a subcollection document owned by a user.
     * Ensures the new document's internal `userId` matches the owner's ID from the path.
     */
    function isCreatingOwnedDoc(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }

    /**
     * Validates updates to a subcollection document owned by a user.
     * Ensures the owner exists and the internal `userId` field is immutable.
     */
    function isUpdatingOwnedDoc(userId) {
      return isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
    }


    //-------------------------------------------------------------------------
    // Collection Rules
    //-------------------------------------------------------------------------

    /**
     * @description Manages user profile documents. A user can create, read,
     *   update, and delete their own profile. Listing all users is forbidden.
     * @path /users/{userId}
     * @allow (create) User 'abc' creating their own profile at `/users/abc`.
     * @deny (list) Any user trying to list all documents at `/users`.
     * @principle Restricts access to a user's own data tree and prevents user enumeration.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isCreatingSelf(userId);
      allow update: if isUpdatingSelf(userId);
      allow delete: if isExistingOwner(userId);

      /**
       * @description Manages a user's income records. Only the owner can
       *   perform any action on their own income records.
       * @path /users/{userId}/incomes/{incomeId}
       * @allow (create) User 'abc' creating an income record at `/users/abc/incomes/xyz`.
       * @deny (get) User 'def' trying to read an income record at `/users/abc/incomes/xyz`.
       * @principle Enforces strict ownership for all subcollection data.
       */
      match /incomes/{incomeId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnedDoc(userId);
        allow update: if isUpdatingOwnedDoc(userId);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Manages a user's expense records. Only the owner can
       *   perform any action on their own expense records.
       * @path /users/{userId}/expenses/{expenseId}
       * @allow (list) User 'abc' listing all their expenses at `/users/abc/expenses`.
       * @deny (update) User 'def' trying to update an expense record at `/users/abc/expenses/xyz`.
       * @principle Enforces strict ownership for all subcollection data.
       */
      match /expenses/{expenseId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnedDoc(userId);
        allow update: if isUpdatingOwnedDoc(userId);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Manages a user's custom income categories. Only the owner can
       *   perform any action on their own categories.
       * @path /users/{userId}/incomeCategories/{incomeCategoryId}
       * @allow (delete) User 'abc' deleting a category at `/users/abc/incomeCategories/xyz`.
       * @deny (create) User 'def' trying to create a category at `/users/abc/incomeCategories/xyz`.
       * @principle Enforces strict ownership for all subcollection data.
       */
      match /incomeCategories/{incomeCategoryId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnedDoc(userId);
        allow update: if isUpdatingOwnedDoc(userId);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Manages a user's custom expense categories. Only the owner can
       *   perform any action on their own categories.
       * @path /users/{userId}/expenseCategories/{expenseCategoryId}
       * @allow (get) User 'abc' reading a category at `/users/abc/expenseCategories/xyz`.
       * @deny (list) User 'def' trying to list categories at `/users/abc/expenseCategories`.
       * @principle Enforces strict ownership for all subcollection data.
       */
      match /expenseCategories/{expenseCategoryId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnedDoc(userId);
        allow update: if isUpdatingOwnedDoc(userId);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Manages a user's budgets. Only the owner can perform
       *   any action on their own budgets.
       * @path /users/{userId}/budgets/{budgetId}
       * @allow (create) User 'abc' creating a budget at `/users/abc/budgets/xyz`.
       * @deny (get) User 'def' trying to read a budget at `/users/abc/budgets/xyz`.
       * @principle Enforces strict ownership for all subcollection data.
       */
      match /budgets/{budgetId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnedDoc(userId);
        allow update: if isUpdatingOwnedDoc(userId);
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMaster() {
      return isSignedIn() && (
        request.auth.token.email == 'grupodallax@gmail.com' || 
        request.auth.token.email == 'vasin71888@him6.com'
      );
    }

    function hasPermission(page, action) {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      let userDoc = exists(userPath) ? get(userPath).data : null;
      
      return isMaster() || (
        userDoc != null && (
          userDoc.role == 'admin' || (
            userDoc.permissions != null && 
            userDoc.permissions[page] != null && 
            userDoc.permissions[page][action] == true
          )
        )
      );
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isMaster() || hasPermission('userManagement', 'view'));
      allow list: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isMaster() || hasPermission('userManagement', 'edit'));

      match /coraTokens/{tokenId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isMaster());
      }
    }

    match /activities/{activityId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('activities', 'view'));
      allow create: if isSignedIn() && (isMaster() || hasPermission('activities', 'create'));
      allow update: if isSignedIn() && (
        isMaster() || 
        hasPermission('activities', 'edit') || 
        resource.data.requesterId == request.auth.uid || 
        resource.data.assigneeId == request.auth.uid
      );
      allow delete: if isSignedIn() && (
        isMaster() || 
        hasPermission('activities', 'delete') || 
        resource.data.requesterId == request.auth.uid
      );
    }

    match /appointments/{appointmentId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('calendar', 'view'));
      allow create: if isSignedIn() && (isMaster() || hasPermission('calendar', 'create'));
      allow update: if isSignedIn() && (isMaster() || hasPermission('calendar', 'edit'));
      allow delete: if isSignedIn() && (isMaster() || hasPermission('calendar', 'delete'));
    }

    match /consultations/{consultationId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('consultations', 'view'));
      allow create: if isSignedIn() && (isMaster() || hasPermission('consultations', 'create'));
      allow update: if isSignedIn() && (isMaster() || hasPermission('consultations', 'edit'));
      allow delete: if isSignedIn() && (isMaster() || hasPermission('consultations', 'delete'));
    }

    match /patients/{patientId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('patients', 'view'));
      allow create: if isSignedIn() && (isMaster() || hasPermission('patients', 'create'));
      allow update: if isSignedIn() && (isMaster() || hasPermission('patients', 'edit'));
      allow delete: if isSignedIn() && (isMaster() || hasPermission('patients', 'delete'));
    }

    match /budgets/{budgetId} {
      allow read: if isSignedIn() && (isMaster() || resource.data.userId == request.auth.uid || hasPermission('budgets', 'view'));
      allow write: if isSignedIn() && (isMaster() || hasPermission('budgets', 'edit'));
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn() && (isMaster() || resource.data.userId == request.auth.uid || hasPermission('contracts', 'view') || hasPermission('transactions', 'view'));
      allow write: if isSignedIn() && (isMaster() || hasPermission('contracts', 'edit') || hasPermission('transactions', 'edit'));
    }

    match /attendanceRecords/{recordId} {
      allow read, write: if isSignedIn() && (request.auth.uid == resource.data.employeeId || isMaster() || hasPermission('timeTracking', 'view'));
    }

    match /timeEntries/{entryId} {
      allow read, write: if isSignedIn() && (request.auth.uid == resource.data.userId || isMaster() || hasPermission('timeTracking', 'view'));
    }

    match /incomes/{docId} {
      allow read: if isSignedIn() && (isMaster() || resource.data.userId == request.auth.uid || hasPermission('transactions', 'view'));
      allow create: if isMaster() || hasPermission('transactions', 'create');
      allow update: if isMaster() || hasPermission('transactions', 'edit');
      allow delete: if isMaster() || hasPermission('transactions', 'delete');
    }

    match /expenses/{docId} {
      allow read: if isSignedIn() && (isMaster() || resource.data.userId == request.auth.uid || hasPermission('transactions', 'view'));
      allow create: if isMaster() || hasPermission('transactions', 'create');
      allow update: if isMaster() || hasPermission('transactions', 'edit');
      allow delete: if isMaster() || hasPermission('transactions', 'delete');
    }

    match /itemCatalog/{docId} {
      allow read: if isSignedIn();
      allow write: if isMaster() || hasPermission('suppliesStock', 'edit');
    }

    match /stock/{docId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('suppliesStock', 'view'));
      allow create: if isMaster() || hasPermission('suppliesStock', 'create');
      allow update: if isMaster() || hasPermission('suppliesStock', 'edit');
      allow delete: if isMaster() || hasPermission('suppliesStock', 'delete');
    }

    match /stockCategories/{docId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('stockCategories', 'view'));
      allow create: if isMaster() || hasPermission('stockCategories', 'create');
      allow update: if isMaster() || hasPermission('stockCategories', 'edit');
      allow delete: if isMaster() || hasPermission('stockCategories', 'delete');
    }

    match /storageLocations/{docId} {
      allow read: if isSignedIn() && (isMaster() || hasPermission('addresses', 'view'));
      allow create: if isMaster() || hasPermission('addresses', 'create');
      allow update: if isMaster() || hasPermission('addresses', 'edit');
      allow delete: if isMaster() || hasPermission('addresses', 'delete');
    }

    match /incomeCategories/{docId} { 
      allow read: if isSignedIn(); 
      allow write: if isMaster() || hasPermission('transactions', 'edit'); 
    }
    
    match /expenseCategoryGroups/{docId} { 
      allow read: if isSignedIn(); 
      allow write: if isMaster() || hasPermission('expenses', 'edit'); 
    }
    
    match /employees/{docId} { 
      allow read: if isSignedIn() && (isMaster() || hasPermission('employees', 'view') || hasPermission('hrTimesheet', 'view')); 
      allow create: if isMaster() || hasPermission('employees', 'create') || hasPermission('hrTimesheet', 'create');
      allow update: if isMaster() || hasPermission('employees', 'edit') || hasPermission('hrTimesheet', 'edit');
      allow delete: if isMaster() || hasPermission('employees', 'delete') || hasPermission('hrTimesheet', 'delete');
    }
    
    match /roles/{docId} { 
      allow read: if isSignedIn(); 
      allow write: if isMaster(); 
    }
  }
}


rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Funções Auxiliares de Segurança
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Administrador Mestre (Verificação direta por Token - Sem latência de banco)
    function isMasterAdmin() {
      return isSignedIn() && (request.auth.token.email == 'grupodallax@gmail.com' || request.auth.token.email == 'vasin71888@him6.com');
    }

    // Verifica se o usuário logado tem o papel de 'admin' no documento de perfil
    function isAdmin() {
      if (!isSignedIn()) return false;
      if (isMasterAdmin()) return true;
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) && get(userPath).data.role == 'admin';
    }

    // Função genérica para verificar permissões granulares
    function hasPermission(module, action) {
      if (!isSignedIn()) return false;
      if (isMasterAdmin()) return true;
      
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      if (!exists(userPath)) return false;
      let userData = get(userPath).data;
      
      // Se for admin no perfil, libera tudo
      if (userData.role == 'admin') return true;
      
      return userData.get('permissions', {}).get(module, {}).get(action, false) == true;
    }

    // ----------------------------------------------------------------------
    // Regras por Coleção
    // ----------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isMasterAdmin() || isAdmin();
      allow list: if isMasterAdmin() || isAdmin();
      allow create: if isOwner(userId) || isMasterAdmin() || isAdmin();
      allow update: if isOwner(userId) || isMasterAdmin() || isAdmin();
      allow delete: if isMasterAdmin() || isAdmin();

      match /coraTokens/{tokenId} {
        allow read, write: if isOwner(userId) || isMasterAdmin() || isAdmin();
      }
    }

    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow write: if isMasterAdmin() || isAdmin();
    }
    
    match /incomes/{docId} {
        allow read: if isSignedIn() && (isMasterAdmin() || isAdmin() || resource.data.userId == request.auth.uid);
        allow write: if isMasterAdmin() || isAdmin() || hasPermission('transactions', 'create');
    }

    match /expenses/{docId} {
        allow read: if isSignedIn() && (isMasterAdmin() || isAdmin() || resource.data.userId == request.auth.uid);
        allow write: if isMasterAdmin() || isAdmin() || hasPermission('transactions', 'create');
    }

    match /budgets/{budgetId} {
      allow read: if isMasterAdmin() || isAdmin() || (resource != null && resource.data.userId == request.auth.uid);
      allow write: if isMasterAdmin() || isAdmin();
    }

    match /incomeCategories/{categoryId} {
        allow read: if isSignedIn();
        allow write: if isMasterAdmin() || isAdmin();
    }

    match /expenseCategoryGroups/{groupId} {
        allow read: if isSignedIn();
        allow write: if isMasterAdmin() || isAdmin();
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn() && (isMasterAdmin() || isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if isMasterAdmin() || isAdmin() || hasPermission('settings', 'view');
    }

    match /employees/{employeeId} {
      allow read: if isSignedIn() && (isMasterAdmin() || isAdmin() || hasPermission('employees', 'view'));
      allow write: if isMasterAdmin() || isAdmin();
    }

    // Regras para a NOVA coleção de ponto (Isolada e Segura)
    match /timeEntries/{entryId} {
      allow list: if isSignedIn() && (isMasterAdmin() || isAdmin() || request.query.limit <= 500);
      allow get: if isSignedIn() && (isMasterAdmin() || isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && (isMasterAdmin() || isAdmin() || request.resource.data.userId == request.auth.uid);
      allow update, delete: if isMasterAdmin() || isAdmin();
    }

    // Regras Legadas (Mantidas para o Beta não quebrar)
    match /attendanceRecords/{recordId} {
      allow list: if isSignedIn() && (isMasterAdmin() || isAdmin() || (request.query.limit <= 500 && resource.data.employeeId == request.auth.uid));
      allow get: if isSignedIn() && (isMasterAdmin() || isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update, delete: if isMasterAdmin() || isAdmin();
    }
  }
}

/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model, often referred to as a "data silo." All user-specific data, such as income, expenses, and file uploads, is stored in subcollections under that user's unique document. This ensures that a user can only ever access their own information. It also includes a role-based access control (RBAC) system managed through a top-level 'roles' collection.
 *
 * Data Structure: The entire data model is hierarchical, starting with the `/users/{userId}` collection. Each user document serves as the root for their private data. The `/roles/{roleId}` collection defines permissions for different user roles ('admin', 'user').
 *
 * Key Security Decisions:
 * - Strict Ownership: Most access is gated by checking if the authenticated user's UID matches the `{userId}` in the document path.
 * - Role-Based Permissions: The 'roles' collection is readable by any signed-in user, allowing the client-side to fetch permissions and adjust the UI accordingly. However, only administrators can modify these roles, ensuring centralized control over application-wide permissions.
 * - No User Listing for Non-Admins: Regular users cannot list the `/users` collection, enhancing privacy. Admins can list users for management purposes.
 * - Path-Based Security: Authorization is derived directly from the document path where possible, making rules fast and simple.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    /**
     * Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the primary function for enforcing data ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * Checks if the requesting user is an administrator by reading their role
     * from their user document.
     */
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }


    /**
     * For update/delete operations, confirms the document exists and the
     * user is the owner. Prevents modifying non-existent data.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * On create, validates that the document's internal 'id' field matches
     * the user's UID from the path, ensuring data consistency.
     */
    function hasCorrectIdOnCreate(userId) {
      return request.resource.data.uid == userId;
    }

    /**
     * On update, ensures a subcollection document's 'userId' field cannot be changed.
     */
    function isUserIdImmutable() {
      // Allow updates for categories which may not have a userId
      return !('userId' in resource.data) || request.resource.data.userId == resource.data.userId;
    }

    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    /**
     * @description A user can manage their own profile document. Admins can manage any user profile.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && hasCorrectIdOnCreate(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }
    
    /**
     * @description The 'roles' collection defines permissions for different user roles.
     * @path /roles/{roleId}
     * @allow Any signed-in user can read permissions to adjust the UI.
     * @deny Only admins can create, update, or delete role permissions.
     */
    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    /**
     * @description A user can manage their own income records.
     * @path /users/{userId}/incomes/{incomeId}
     */
    match /users/{userId}/incomes/{incomeId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) && isUserIdImmutable();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description A user can manage their own expense records.
     * @path /users/{userId}/expenses/{expenseId}
     */
    match /users/{userId}/expenses/{expenseId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) && isUserIdImmutable();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description A user can manage their own budget records.
     * @path /users/{userId}/budgets/{budgetId}
     */
    match /users/{userId}/budgets/{budgetId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) && isUserIdImmutable();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description A user can manage their own file upload metadata records.
     * @path /users/{userId}/fileUploads/{fileUploadId}
     */
    match /users/{userId}/fileUploads/{fileUploadId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) && isUserIdImmutable();
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description A user can manage their own income categories.
     * @path /users/{userId}/incomeCategories/{categoryId}
     */
    match /users/{userId}/incomeCategories/{categoryId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description A user can manage their own expense categories.
     * @path /users/{userId}/expenseCategories/{categoryId}
     */
    match /users/{userId}/expenseCategories/{categoryId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }
  }
}

    
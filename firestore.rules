
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Helper Functions
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Checks if the user's document exists and has the role 'admin'.
      // This is safer than accessing .data directly, which errors if the doc doesn't exist.
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOriginalCreator() {
      // This works for create and update where request.resource.data is available.
      return isSignedIn() && request.auth.uid == request.resource.data.userId;
    }
    
    function isExistingDocOwner(docId, collectionName) {
      // Checks if the document exists before trying to access its data.
      return isSignedIn() && exists(/databases/$(database)/documents/$(collectionName)/$(docId)) &&
             get(/databases/$(database)/documents/$(collectionName)/$(docId)).data.userId == request.auth.uid;
    }


    // ----------------------------------------------------------------------
    // Collection Rules
    // ----------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin() || (
                    exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("permissions", {}).get("userManagement", {}).get("view", false) == true
                   );
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /coraTokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /incomes/{docId} {
        allow read: if isSignedIn();
        allow list: if isAdmin();
        allow create: if isOriginalCreator();
        allow update: if isExistingDocOwner(docId, 'incomes') || isAdmin();
        allow delete: if isExistingDocOwner(docId, 'incomes') || isAdmin();
    }

    match /expenses/{docId} {
        allow read: if isSignedIn();
        allow list: if isAdmin();
        allow create: if isOriginalCreator();
        allow update: if isExistingDocOwner(docId, 'expenses') || isAdmin();
        allow delete: if isExistingDocOwner(docId, 'expenses') || isAdmin();
    }

    match /budgets/{budgetId} {
      allow read: if isAdmin() || resource.data.userId == request.auth.uid;
      allow create: if isOriginalCreator();
      allow update: if isExistingDocOwner(budgetId, 'budgets') || isAdmin();
      allow delete: if isExistingDocOwner(budgetId, 'budgets') || isAdmin();
    }

    match /incomeCategories/{categoryId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
    }

    match /expenseCategoryGroups/{groupId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin();
    }

    match /contracts/{contractId} {
      allow read, list: if isSignedIn();
      allow create: if isOriginalCreator();
      allow update: if isExistingDocOwner(contractId, 'contracts') || isAdmin();
      allow delete: if isExistingDocOwner(contractId, 'contracts') || isAdmin();
    }

    match /employees/{employeeId} {
      allow read, list: if isSignedIn();
      allow create: if isOriginalCreator();
      allow update: if isExistingDocOwner(employeeId, 'employees') || isAdmin();
      allow delete: if isAdmin();
    }
  }
}

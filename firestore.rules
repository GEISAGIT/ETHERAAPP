
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // Funções Auxiliares de Segurança
    // ----------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Verifica se o usuário logado tem o papel de 'admin'
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Função genérica para verificar permissões granulares no mapa de permissões
    // Exemplo: hasPermission('employees', 'create')
    function hasPermission(module, action) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('permissions', {}).get(module, {}).get(action, false) == true
             );
    }

    function isOriginalCreator() {
      return isSignedIn() && request.auth.uid == request.resource.data.userId;
    }
    
    function isExistingDocOwner(docId, collectionName) {
      return isSignedIn() && exists(/databases/$(database)/documents/$(collectionName)/$(docId)) &&
             get(/databases/$(database)/documents/$(collectionName)/$(docId)).data.userId == request.auth.uid;
    }


    // ----------------------------------------------------------------------
    // Regras por Coleção
    // ----------------------------------------------------------------------

    match /users/{userId} {
      // Permite leitura se for o dono ou se tiver permissão de gerenciar usuários
      allow get: if isOwner(userId) || hasPermission('userManagement', 'view');
      // Apenas administradores ou gestores de usuários podem listar todos
      allow list: if hasPermission('userManagement', 'view');
      // Permite criar se for o próprio usuário (autocadastro) ou se tiver permissão de RH/Funcionários/UserManagement
      allow create: if isOwner(userId) || hasPermission('employees', 'create') || hasPermission('userManagement', 'create');
      // Permite atualizar se for o dono ou se tiver permissão de edição de usuários
      allow update: if isOwner(userId) || hasPermission('userManagement', 'edit');
      // Apenas administradores ou gestores autorizados podem excluir contas
      allow delete: if hasPermission('userManagement', 'delete');

      match /coraTokens/{tokenId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /roles/{roleId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /incomes/{docId} {
        allow read: if isSignedIn();
        allow list: if hasPermission('transactions', 'view') || hasPermission('reports', 'view');
        allow create: if hasPermission('transactions', 'create');
        allow update: if hasPermission('transactions', 'edit');
        allow delete: if hasPermission('transactions', 'delete');
    }

    match /expenses/{docId} {
        allow read: if isSignedIn();
        allow list: if hasPermission('transactions', 'view') || hasPermission('reports', 'view');
        allow create: if hasPermission('transactions', 'create');
        allow update: if hasPermission('transactions', 'edit');
        allow delete: if hasPermission('transactions', 'delete');
    }

    match /budgets/{budgetId} {
      allow read: if hasPermission('budgets', 'view') || resource.data.userId == request.auth.uid;
      allow create: if hasPermission('budgets', 'create');
      allow update: if hasPermission('budgets', 'edit');
      allow delete: if hasPermission('budgets', 'delete');
    }

    match /incomeCategories/{categoryId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
    }

    match /expenseCategoryGroups/{groupId} {
        allow get, list: if isSignedIn();
        allow write: if isAdmin();
    }

    match /contracts/{contractId} {
      allow read, list: if isSignedIn();
      allow create: if hasPermission('transactions', 'create') || hasPermission('settings', 'view');
      allow update: if hasPermission('transactions', 'edit') || hasPermission('settings', 'view');
      allow delete: if hasPermission('transactions', 'delete') || hasPermission('settings', 'view');
    }

    match /employees/{employeeId} {
      allow read, list: if hasPermission('employees', 'view');
      allow create: if hasPermission('employees', 'create');
      allow update: if hasPermission('employees', 'edit');
      allow delete: if hasPermission('employees', 'delete');
    }
  }
}
